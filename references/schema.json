{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/osama-2000236/claude-codex-teamflow/schema.json",
  "title": "Codex Review Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["goal", "plan_source", "changed_files", "diff_summary", "qa", "risks"],
  "properties": {
    "goal": {"type": "string"},
    "plan_source": {"type": "string"},
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "subsystem"],
        "properties": {
          "path": {"type": "string"},
          "subsystem": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "diff_summary": {"type": "string"},
    "qa": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result"],
        "properties": {
          "command": {"type": "string"},
          "result": {"type": "string", "enum": ["pass", "fail", "skipped"]},
          "evidence": {"type": "string"}
        }
      }
    },
    "risks": {"type": "array", "items": {"type": "string"}},
    "questions": {"type": "array", "items": {"type": "string"}}
  }
}
